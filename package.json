{
  "name": "farewell-naver-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "lefthook install",
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --silent",
    "test:offline": "vitest run --silent --exclude tests/naver.integration.test.ts",
    "test:network": "vitest run tests/naver.integration.test.ts --silent",
    "docs:check": "tsx scripts/harness/check-doc-graph.ts",
    "parser:check": "tsx scripts/harness/check-parser-capabilities.ts",
    "samples:verify": "tsx scripts/harness/verify-sample-exports.ts",
    "smoke:ui": "tsx scripts/harness/run-ui-smoke.ts",
    "quality:report": "tsx scripts/harness/generate-quality-report.ts",
    "check:local": "pnpm typecheck && pnpm test:offline && pnpm docs:check && pnpm parser:check",
    "check:quick": "pnpm check:local",
    "check:full": "pnpm quality:report && pnpm check:local && pnpm test:network && pnpm samples:verify && pnpm smoke:ui",
    "check": "pnpm check:full"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "jsdom": "^26.1.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.6.0",
    "@types/turndown": "^5.0.6",
    "lefthook": "2.1.4",
    "playwright": "^1.59.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
