{
  "name": "farewell-naver-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/server.ts",
    "start": "pnpm build:ui && tsx src/server.ts",
    "build:ui": "vite build",
    "build:server": "tsc -p tsconfig.json",
    "build": "pnpm build:ui && pnpm build:server",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --silent",
    "test:coverage": "vitest run --silent --coverage",
    "test:offline": "vitest run --silent",
    "test:network:upload": "pnpm build:ui && tsx scripts/harness/run-ui-live-upload.ts",
    "parser:check": "tsx scripts/harness/check-parser-capabilities.ts",
    "samples:verify": "tsx scripts/harness/verify-sample-exports.ts",
    "samples:refresh": "tsx scripts/harness/refresh-sample-fixtures.ts",
    "smoke:ui": "pnpm build:ui && tsx scripts/harness/run-ui-smoke.ts",
    "quality:report": "tsx scripts/harness/generate-quality-report.ts",
    "check:local": "pnpm typecheck && pnpm test:offline && pnpm parser:check",
    "check:quick": "pnpm check:local",
    "check:full": "pnpm quality:report && pnpm check:local && pnpm samples:verify && pnpm smoke:ui",
    "check": "pnpm check:full"
  },
  "dependencies": {
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "cheerio": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "domhandler": "^5.0.3",
    "piclist": "2.3.5",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^26.1.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vitest": "^3.2.4"
  }
}
